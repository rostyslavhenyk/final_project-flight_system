{% extends "_layout/base.peb" %}

{% block content %}
<br>
{% if logged_in %}
    <h1 style="text-align: center;">Welcome {{ user.firstname }}!</h1>
{% else %}
    <h1 style="text-align: center;">Welcome to the (company)!</h1>
{% endif %}

<p class="plain-text">Welcome to the homepage!</p>


{% endblock %}
