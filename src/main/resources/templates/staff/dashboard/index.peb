{% extends "_layout/basestaff.peb" %}

{% block content %}
<section class="staff-shell">
    <header class="staff-hero">
        <h1>Staff Dashboard</h1>
        <p>Welcome, {{ user.firstname }}!</p>
    </header>

    <section class="staff-dashboard-grid" aria-label="Dashboard metrics">
        <article class="staff-dashboard-card">
            <div class="staff-dashboard-card__head">
                <div>
                    <span class="staff-card__label">Seat sales</span>
                    <h2>Total sold seats</h2>
                </div>
                <div class="staff-dashboard-toggle" role="group" aria-label="Sold seats range">
                    <button type="button" class="staff-dashboard-toggle__btn staff-dashboard-toggle__btn--active" data-sales-range="day" aria-pressed="true">Day</button>
                    <button type="button" class="staff-dashboard-toggle__btn" data-sales-range="week" aria-pressed="false">7 days</button>
                    <button type="button" class="staff-dashboard-toggle__btn" data-sales-range="fourWeeks" aria-pressed="false">28 days</button>
                </div>
            </div>

            <div class="staff-pie-panel" data-sales-chart="day">
                <div class="staff-pie staff-pie--sales" style="--pie-main: {{ soldFlightsPercentToday }}%;" aria-label="{{ soldFlightsPercentToday }} percent sold"></div>
                <div class="staff-pie-details">
                    <strong>{{ soldFlightsToday }}</strong>
                    <span>sold seats today</span>
                    <p>{{ soldFlightsRealToday }} real bookings, {{ soldFlightsSimulatedToday }} simulated taken seats, {{ soldFlightsRemainingToday }} available across {{ flightCountToday }} flights.</p>
                </div>
            </div>
            <div class="staff-pie-panel" data-sales-chart="week" hidden>
                <div class="staff-pie staff-pie--sales" style="--pie-main: {{ soldFlightsPercentWeek }}%;" aria-label="{{ soldFlightsPercentWeek }} percent sold"></div>
                <div class="staff-pie-details">
                    <strong>{{ soldFlightsWeek }}</strong>
                    <span>sold seats in 7 days</span>
                    <p>{{ soldFlightsRealWeek }} real bookings, {{ soldFlightsSimulatedWeek }} simulated taken seats, {{ soldFlightsRemainingWeek }} available across {{ flightCountWeek }} flights.</p>
                </div>
            </div>
            <div class="staff-pie-panel" data-sales-chart="fourWeeks" hidden>
                <div class="staff-pie staff-pie--sales" style="--pie-main: {{ soldFlightsPercentFourWeeks }}%;" aria-label="{{ soldFlightsPercentFourWeeks }} percent sold"></div>
                <div class="staff-pie-details">
                    <strong>{{ soldFlightsFourWeeks }}</strong>
                    <span>sold seats in 28 days</span>
                    <p>{{ soldFlightsRealFourWeeks }} real bookings, {{ soldFlightsSimulatedFourWeeks }} simulated taken seats, {{ soldFlightsRemainingFourWeeks }} available across {{ flightCountFourWeeks }} flights.</p>
                </div>
            </div>
        </article>

        <article class="staff-dashboard-card">
            <span class="staff-card__label">Tickets</span>
            <h2>Active tickets</h2>
            <div class="staff-ticket-widget">
                <div>
                    <strong>{{ activeUserTickets }}</strong>
                    <span>User tickets</span>
                </div>
                <div>
                    <strong>{{ activeStaffTickets }}</strong>
                    <span>Staff tickets</span>
                </div>
            </div>
            <p class="staff-dashboard-note">{{ activeTicketTotal }} open or in progress in total.</p>
        </article>

        <article class="staff-dashboard-card">
            <span class="staff-card__label">Live Chat</span>
            <h2>Open conversations</h2>
            <div class="staff-ticket-widget">
                <div>
                    <strong>{{ openChatCount }}</strong>
                    <span>Open chats</span>
                </div>
            </div>
            <a href="/staff/chat" class="btn-staff-link">View messages</a>
        </article>

        <article class="staff-dashboard-card">
            <span class="staff-card__label">Sales target</span>
            <h2>28 day target</h2>
            <div class="staff-pie-panel staff-pie-panel--compact">
                <div class="staff-pie staff-pie--target" style="--pie-main: {{ salesTargetChartPercent }}%; --pie-overflow: {{ salesTargetOverflowPercent }}%;" aria-label="{{ salesTargetProgressPercent }} percent reached"></div>
                <div class="staff-pie-details">
                    <strong>GBP {{ salesReached28DaysPlain }}</strong>
                    <span>of GBP {{ salesTarget28DaysPlain }}</span>
                </div>
            </div>
            <p class="staff-dashboard-note">{{ salesTargetProgressPercent }}% reached.</p>
        </article>

        <article class="staff-dashboard-card">
            <span class="staff-card__label">Live chat</span>
            <h2>Unread messages</h2>
            <div class="staff-dashboard-count" data-staff-chat-dashboard-count aria-live="polite" aria-atomic="true">{{ unreadChatConversations }}</div>
            <p class="staff-dashboard-note">Customer conversations waiting for a staff reply.</p>
        </article>
    </section>
</section>
<script src="/static/js/staff-dashboard.js" defer></script>
{% endblock %}
