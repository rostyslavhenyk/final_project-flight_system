<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Staff Panel{% endblock %}</title>
    <link rel="icon" href="/static/images/LogoForTab.svg" type="image/svg+xml">

    <link rel="stylesheet" href="/static/css/base.css">
    <link rel="stylesheet" href="/static/css/staff/panel.css">
    {% block styles %}{% endblock %}
    <script src="/static/js/htmx-1.9.12.min.js" defer></script>
</head>
<body>
    <a class="skip-link" href="#main">Skip to main content</a>

    <div id="status"></div>

    <header id="navbar">
        <div class="brand">
            <a href="/staff" class="brand-link brand-link--logo brand-link--staff-logo" aria-label="Glide Staff home">
                <img class="brand-logo brand-logo--staff" src="/static/images/StaffLogo.svg" alt="Glide Staff">
            </a>
        </div>
        <nav>
            <ul class="main-links">
                <li><a href="/staff">Dashboard</a></li>
                <li><a href="/staff/flights">Flights</a></li>
                <li><a href="/staff/users">Users</a></li>
                {% if isStaffAdmin %}
                <li><a href="/staff/staff-accounts">Create Staff</a></li>
                {% endif %}
                <li><a href="/staff/tickets">Tickets</a></li>
                <li><a href="/staff/chat">Chat</a></li>
            </ul>
            <ul class="auth-links">
                <li><a href="/staff/my-account">My Account</a></li>
                <li>
                    <form action="/logout" method="post" class="nav-inline-form">
                        <button type="submit" class="nav-inline-button">Log Out</button>
                    </form>
                </li>
            </ul>
        </nav>
    </header>

    <main id="main" tabindex="-1">
        {% block content %}{% endblock %}
    </main>
</body>
</html>
