<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Flight System{% endblock %}</title>
    <link rel="icon" href="/static/images/LogoForTab.svg" type="image/svg+xml">

    <link rel="stylesheet" href="/static/css/base.css">
    {% block styles %}{% endblock %}
    {% block extra_head %}{% endblock %}
    <script src="/static/js/htmx-1.9.12.min.js" defer></script>
</head>
<body class="{% block body_class %}{% endblock %}">
    {# Skip link: first focusable element for keyboard / screen reader users #}
    <a class="skip-link" href="#main">Skip to main content</a>

    {# HTMX / app status messages (polite so assistive tech does not interrupt mid-task) #}
    <div id="status" role="status" aria-live="polite"></div>

    {# Global top navigation #}
    <header id="navbar">
        <div class="brand">
            <a href="/" class="brand-link brand-link--logo" aria-label="Glide Airways home">
                <img class="brand-logo brand-logo--user" src="/static/images/UserLogo.svg" alt="Glide Airways">
            </a>
        </div>
        <nav>
            <ul class="main-links">
                <li><a href="/flights">Flights</a></li>
                <li><a href="/membership">Membership</a></li>
                <li><a href="/help">Help</a></li>
            </ul>
            <ul class="auth-links">
                {% if loggedIn %}
                    <li><a href="/my-account">My Account</a></li>
                    <li>
                        <form action="/logout" method="post" class="nav-inline-form">
                            <button type="submit" class="nav-inline-button">Log Out</button>
                        </form>
                    </li>
                {% else %}
                    <li><a href="/signup">Sign Up</a></li>
                    <li><a href="/login">Log In</a></li>
                {% endif %}
            </ul>
        </nav>
    </header>

    <main id="main" tabindex="-1">
        {# Main page content (overridden by each template) #}
        {% block content %}{% endblock %}
    </main>

    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-top">
                <a href="/commitment">Our commitment to you</a>
                <span class="footer-sep" aria-hidden="true">|</span>
                <a href="/help">Contact us</a>
                <span class="footer-sep" aria-hidden="true">|</span>
                <a href="/legal">Legal and Privacy</a>
            </div>
            <div class="footer-links">
                <p id="connect_with_us">Connect with us</p>
                <div class="social-icons">
                    <span class="icon-circle"><img src="/static/images/facebook_icon.svg" alt="Facebook"></span>
                    <span class="icon-circle"><img src="/static/images/instagram_icon.svg" alt="Instagram"></span>
                    <span class="icon-circle"><img src="/static/images/x_icon.svg" alt="X"></span>
                </div>
                <p id="credits">Visual design references modern airline booking websites.</p>
            </div>
        </div>
    </footer>
</body>
</html>
